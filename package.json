{
  "name": "tollvord-pro",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "type": "module",
  "scripts": {
    "build": "corepack pnpm -r build",
    "dev": "corepack pnpm --filter @tollvord/web dev",
    "lint": "corepack pnpm -r lint && node tools/check-docs.mjs",
    "prisma:validate": "DATABASE_URL=postgresql://user:password@localhost:5432/tollvord_pro corepack pnpm exec prisma validate --schema prisma/schema.prisma",
    "test": "corepack pnpm -r test && node tools/check-schema.mjs",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "prisma": "6.1.0",
    "typescript": "5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  }
}
