# Frigg API
FRIGG_API_PORT=4310

# Repository driver
# Gild gildi eru `memory` og `file`.
FRIGG_REPOSITORY_DRIVER=memory

# File-based seed sources
# Notað þegar `FRIGG_REPOSITORY_DRIVER=file`.
FRIGG_REPOSITORY_FILE=./db/seeds/demo-repository.json
FRIGG_RESEARCH_WORKSPACE_FILE=./db/seeds/research-workspace.json

# AI provider tokens
# Skildu eftir tómt ef viðkomandi veitandi er ekki tengdur í þessari vél.
GITHUB_MODELS_TOKEN=
GEMINI_API_KEY=
SAMBANOVA_API_KEY=
MISTRAL_API_KEY=
